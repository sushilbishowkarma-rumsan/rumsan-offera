{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "dev": { "cache": false, "persistent": true },
    "db:generate": {
      "cache": false,
      "outputs": [] 
    },
    "build": {
      "dependsOn": ["^build", "db:generate"],
      "outputs": [".next/**", "dist/**"],
       "env": [
        "NEXT_PUBLIC_SERVER_API",
        "NEXT_PUBLIC_GOOGLE_CLIENT_ID"
      ]
    }
  }
}